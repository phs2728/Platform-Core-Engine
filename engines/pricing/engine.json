{
  "id": "pricing",
  "name": "Pricing Engine",
  "version": "1.0.0-rc2",
  "phase": 4,
  "status": "RC2",
  "description": "[사장님 확립 2026-07-11] Business Foundation Phase 4. Industry-Agnostic pricing plan management — plans, components, tiers, time-based pricing, currencies, versions, history. Organization ownership enforced. NOT a calculation engine — manages pricing models only.",
  "depends_on": [
    "core-sdk",
    "policy",
    "organization",
    "catalog",
    "event-bus"
  ],
  "provides": [
    "createPricingPlan",
    "updatePricingPlan",
    "archivePricingPlan",
    "restorePricingPlan",
    "deletePricingPlan",
    "getPricingPlan",
    "listPricingPlans",
    "searchPricingPlans",
    "createPrice",
    "updatePrice",
    "archivePrice",
    "restorePrice",
    "addPriceComponent",
    "removePriceComponent",
    "createTierPricing",
    "updateTierPricing",
    "deleteTierPricing",
    "createTimePricing",
    "updateTimePricing",
    "deleteTimePricing",
    "registerCurrency",
    "changeBaseCurrency",
    "updateExchangeRate",
    "publishPriceVersion",
    "rollbackPriceVersion",
    "getPriceHistory",
    "attachCatalog",
    "detachCatalog"
  ],
  "events_emitted": [
    "pricing.plan.created",
    "pricing.plan.updated",
    "pricing.plan.archived",
    "pricing.plan.restored",
    "pricing.plan.deleted",
    "pricing.created",
    "pricing.updated",
    "pricing.archived",
    "pricing.restored",
    "pricing.deleted",
    "pricing.version.published",
    "pricing.version.rollback",
    "pricing.currency.updated",
    "pricing.exchange.updated",
    "pricing.component.added",
    "pricing.component.removed",
    "pricing.tier.created",
    "pricing.tier.updated",
    "pricing.time.created",
    "pricing.time.updated",
    "pricing.catalog.attached",
    "pricing.catalog.detached",
    "pricing.audit.recorded"
  ],
  "events_subscribed": [
    "organization.archived",
    "organization.deleted",
    "catalog.archived"
  ],
  "strict_boundaries": {
    "owns": [
      "PricingPlan",
      "PriceComponent",
      "Price",
      "Currency",
      "TierPricing",
      "TimePricing",
      "PriceVersion",
      "PriceHistory",
      "ExchangeRate",
      "PricingAudit"
    ],
    "forbidden": [
      "Authentication",
      "Password",
      "Session",
      "OAuth",
      "MFA",
      "Permission",
      "Role",
      "TransactionProcessing",
      "TransactionCapture",
      "TransactionRefund",
      "InventoryManagement",
      "StockQuantity",
      "SlotManagementSystems",
      "TransactionalCommerce",
      "FinancialDocuments",
      "TaxCalculationLogic",
      "DiscountComputationLogic",
      "CouponEngine",
      "PromotionEngineImplementation",
      "MediaStorageManagement",
      "AddressRawField",
      "EmailRawField",
      "PhoneRawField",
      "IndustrySpecificField"
    ]
  }
}