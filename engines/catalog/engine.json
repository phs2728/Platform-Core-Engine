{
  "id": "catalog",
  "name": "Catalog Engine",
  "version": "1.0.0-rc2",
  "phase": 4,
  "status": "RC2",
  "description": "[사장님 확립 2026-07-11 Business Foundation Phase 4] Reference Business Engine. Industry-Agnostic catalog of items, categories, variants, bundles — Organization ownership enforced, CustomDataPolicy validation at UseCase entry, attributes/customFields/metadata as free-form JSON.",
  "depends_on": [
    "core-sdk",
    "policy",
    "user",
    "organization",
    "event-bus"
  ],
  "provides": [
    "createCatalog",
    "updateCatalog",
    "archiveCatalog",
    "restoreCatalog",
    "deleteCatalog",
    "getCatalog",
    "listCatalogs",
    "searchCatalogs",
    "createCategory",
    "updateCategory",
    "moveCategory",
    "deleteCategory",
    "createVariant",
    "updateVariant",
    "deleteVariant",
    "createBundle",
    "updateBundle",
    "deleteBundle",
    "assignMediaRef",
    "assignPricingRef"
  ],
  "events_emitted": [
    "catalog.created",
    "catalog.updated",
    "catalog.archived",
    "catalog.restored",
    "catalog.deleted",
    "category.created",
    "category.updated",
    "category.moved",
    "category.deleted",
    "variant.created",
    "variant.updated",
    "variant.deleted",
    "bundle.created",
    "bundle.updated",
    "bundle.deleted",
    "reference.media.assigned",
    "reference.pricing.assigned",
    "catalog.audit.recorded"
  ],
  "events_subscribed": [
    "organization.archived",
    "organization.deleted",
    "user.deleted"
  ],
  "strict_boundaries": {
    "owns": [
      "Catalog",
      "Category",
      "Item",
      "Variant",
      "Bundle",
      "Reference",
      "CatalogAudit"
    ],
    "forbidden": [
      "Authentication",
      "Password",
      "Session",
      "OAuth",
      "MFA",
      "Permission",
      "Role",
      "InventoryManagement",
      "StockManagement",
      "SlotManagementSystems",
      "FinancialTransactions",
      "TransactionalCommerce",
      "FinancialDocuments",
      "TaxData",
      "PriceComputation",
      "DiscountComputation",
      "PricingPolicyManagement",
      "MediaStorageManagement",
      "MediaUploadManagement",
      "AddressRawField",
      "EmailRawField",
      "PhoneRawField",
      "IndustrySpecificField"
    ]
  }
}