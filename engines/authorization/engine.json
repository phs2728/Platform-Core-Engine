{
  "id": "authorization",
  "name": "Authorization Engine",
  "version": "1.0.0-rc2",
  "phase": 4,
  "status": "RC2",
  "description": "Universal Authorization Engine — RBAC + ABAC + Policy + Resource + Permission Simulator. Decision Engine orchestrates all Resolvers. Expression-based ABAC. explain() API.",
  "depends_on": [
    "core-sdk",
    "universal-core"
  ],
  "provides": [
    "authorize",
    "can",
    "cannot",
    "evaluate",
    "explain",
    "simulatePermissionsUseCase",
    "whatIfUseCase",
    "createRoleUseCase",
    "assignPermissionToRoleUseCase",
    "assignRoleUseCase",
    "createPolicyUseCase"
  ],
  "events_emitted": [
    "authorization.role.created",
    "authorization.role.assigned",
    "authorization.permission.assigned",
    "authorization.policy.created",
    "authorization.decision.allow",
    "authorization.decision.deny"
  ],
  "events_subscribed": []
}