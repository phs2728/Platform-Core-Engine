{
  "name": "@aibg/engine-policy",
  "version": "0.1.0",
  "description": "Policy Engine — Configuration SSoT with 3-tier policy resolution (Global / Engine / Tenant)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "echo 'lint: deferred to monorepo root'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aibg/core": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
