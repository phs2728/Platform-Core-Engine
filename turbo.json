{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "tsconfig.build.json",
        "package.json"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/**",
        "vitest.config.ts",
        "tsconfig.json"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/**",
        "vitest.config.ts"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:security": {
      "dependsOn": ["^build"],
      "inputs": [
        "test/security/**",
        "src/**"
      ]
    },
    "lint": {
      "inputs": [
        "src/**",
        "test/**",
        ".eslintrc.cjs",
        ".eslintignore"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/**",
        "tsconfig.json"
      ],
      "outputs": []
    },
    "industry-agnostic": {
      "inputs": [
        "src/**",
        "docs/**",
        "db/**"
      ],
      "outputs": []
    }
  }
}
